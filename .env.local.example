# Copy this file to .env.local and fill in real values from your Supabase project settings.
# NEVER commit .env.local — it is already gitignored.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key bypasses Row Level Security — server-only, used for admin
# tasks (creating users from Settings, etc). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
